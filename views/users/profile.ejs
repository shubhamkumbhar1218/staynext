<% layout("layouts/boilerplate.ejs") %>

<div class="container_p mt-4 mb-4 d-flex justify-content-center">
    <div class="profile-card text-center">

        <!-- Username / Email -->
        <h2><%= currUser.username %></h2>
        <p class="text-muted">Welcome to your profile </p>

        <hr>

        <!-- User Info -->
        <div class="text-start mt-3">
            <p><strong>Email:</strong> <%= currUser.email %></p>
            <p><strong>Username:</strong> <%= currUser.username %></p>
        </div>

        <hr>

        <!-- Buttons -->
        <div class="d-flex justify-content-between mt-4">
            <a href="/listing" class="btn btn-success text-white">Home</a>
            <a href="/logout" class="btn btn-danger">Logout</a>
        </div>

    </div>
</div>
<br><br><br><br><br>
